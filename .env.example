# LLM Provider
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Database (default: SQLite, switch to PostgreSQL when Docker is running)
DATABASE_URL=sqlite+aiosqlite:///./knot.db
# DATABASE_URL=postgresql+asyncpg://knot:knot_dev@localhost:5432/knot

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
